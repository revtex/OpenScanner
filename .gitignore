# Binaries
/backend/openscanner
/backend/server
/backend/migrate
/backend/vendor/
/build/

# Embedded frontend dist (build artifact)
/backend/internal/static/dist/*
!/backend/internal/static/dist/.gitkeep

# Generated Swagger artifacts
/backend/docs/

# Node
/frontend/node_modules/
/frontend/dist/

# Data & audio (dev)
/data/
/audio/
*.m4a

# mosquitto runtime — keep config/ committed, ignore data and the passwd
# file (created at runtime via `mosquitto_passwd` inside the container so
# it has the correct UID 1883 ownership and 0700 perms).
/mosquitto/data/
/mosquitto/config/passwd

# SQLite DB files
*.db
*.db-shm
*.db-wal

# Env
.env
.env.local

# OS
.DS_Store
Thumbs.db

# pnpm store (devcontainer volume mount fallback)
/.pnpm-store/

# Reference implementation
/reference/

# Dev temp files
/backend/tmp/

# Dev audio recordings
/recordings/

# In-progress planning docs
/docs/plans/

/systems-config/
# Local preview (not meant to be committed)
/tmp-pdf-preview/

# AI assistant / MCP session artifacts (machine-specific, not shared)
/.claude/
/.mcp.json
/.playwright-mcp/
/test-playwright.png
