# Default: normalise all text files to LF in the repository.
* text=auto eol=lf

# Explicit binary types — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp3 binary
*.wav binary
*.m4a binary
*.flac binary
*.opus binary
*.zip binary
*.gz binary
*.tar binary
*.pdf binary
